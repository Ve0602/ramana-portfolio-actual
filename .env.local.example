# ─────────────────────────────────────────────────────────────
# CareerFlow AI — Environment Variables
# ─────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file and rename to: .env.local
#   2. Fill in each value below
#   3. Never share this file or push to GitHub
# ─────────────────────────────────────────────────────────────

# ── SUPABASE ──────────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOURPROJECTID.supabase.co
# Example: https://xyzabc1234567890.supabase.co

NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXX
# The "anon public" key — starts with eyJ

SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXX
# The "service_role" key — KEEP SECRET, never expose to browser

# ── GEMINI AI (FREE) ──────────────────────────────────────────
# Get free key from: aistudio.google.com/app/apikey

GEMINI_API_KEY=AIzaSy_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Starts with AIzaSy — 60 requests/min free

# ── NEXT.JS ───────────────────────────────────────────────────

NEXTAUTH_SECRET=careerflow-super-secret-key-change-this-2024
# Any random long string — used for session security

NEXT_PUBLIC_BRAND_NAME=CareerFlow AI
# Your brand name — shows in AI responses

# ── RAZORPAY (add later when ready to charge) ─────────────────
# Get from: razorpay.com → Settings → API Keys
# Complete KYC first (Aadhaar + PAN + Bank account)

NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
# Use rzp_test_ prefix for testing, rzp_live_ for real payments

RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXX
# Keep this SECRET — only used server-side

RAZORPAY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXX
# From Razorpay Dashboard → Webhooks → add webhook → copy secret

# ── EMAIL (optional — add when you want to send emails) ───────
# Get free 3000 emails/month from: resend.com

RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX
# Used to send welcome emails, application notifications etc.

# ── YOUR SITE URL ─────────────────────────────────────────────

NEXT_PUBLIC_SITE_URL=https://careerflow-ai.vercel.app
# Your actual deployed URL — used in email links etc.
